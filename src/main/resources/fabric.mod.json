{
  "schemaVersion": 1,
  "id": "$id",
  "version": "$version",
  "name": "Conflux Map",
  "description": "Minimap and world map with multiplayer-aware features: HUD minimap, fullscreen map, waypoints, death points, cave/nether layers, entity radar, and an in-game settings screen.",
  "authors": [
    "Conflux Union"
  ],
  "contact": {
    "homepage": "https://github.com/Conflux-Union/conflux-map",
    "sources": "https://github.com/Conflux-Union/conflux-map"
  },
  "license": "GPL-3.0",
  "icon": "assets/$id/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "cn.net.rms.confluxmap.ConfluxMapMod"
    ],
    "client": [
      "cn.net.rms.confluxmap.ConfluxMapClient"
    ]
  },
  "mixins": [
    "${id}.mixins.json"
  ],
  "accessWidener": "${id}.accesswidener",
  "depends": {
    "fabricloader": ">=$loader_version",
    "fabric": "*",
    "minecraft": "$minecraft_version"
  }
}
